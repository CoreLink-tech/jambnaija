{
  "version": 2,
  "buildCommand": "npm install && npm --prefix backend run prisma:generate",
  "functions": {
    "api/index.mjs": {
      "runtime": "nodejs22.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/",
      "destination": "/hi.html"
    }
  ]
}
