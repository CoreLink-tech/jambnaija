# Supabase pooled connection (used by app/runtime)
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase direct connection (used by Prisma migrations)
DIRECT_DATABASE_URL="postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres"

PORT=4000
JWT_SECRET="replace-with-long-random-secret"
# Use "*" for same-domain/fullstack deployment, or set comma-separated frontend domains
CORS_ORIGIN="*"

# Optional admin bootstrap endpoint key
ADMIN_BOOTSTRAP_KEY="replace-with-bootstrap-key"

# For seed:admin
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-please"
